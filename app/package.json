{
	"name": "app",
	"private": true,
	"version": "0.0.1",
	"packageManager": "bun@1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "bun run build && vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.55.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22",
		"@vitest/browser": "^3.2.4",
		"@xmldom/xmldom": "^0.8.11",
		"daisyui": "^5.3.7",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"mdsvex": "^0.12.6",
		"phosphor-svelte": "^3.0.1",
		"playwright": "^1.55.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"tailwindcss": "^4.1.13",
		"tsx": "^4.20.6",
		"typescript-eslint": "^8.46.1",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"dependencies": {
		"@apatopwa/tei-transcription": "file:../packages/tei-transcription",
		"@djazzkit/core": "file:../djazzkit/packages/core",
		"@djazzkit/svelte": "file:../djazzkit/packages/svelte",
		"@floating-ui/dom": "^1.7.4",
		"@tiptap/core": "^3.7.2",
		"@tiptap/extension-bubble-menu": "^3.7.2",
		"@tiptap/extension-document": "^3.7.2",
		"@tiptap/extension-floating-menu": "^3.7.2",
		"@tiptap/extension-history": "^3.7.2",
		"@tiptap/extension-text": "^3.7.2",
		"@tiptap/extensions": "^3.7.2",
		"@tiptap/pm": "^3.7.2",
		"collatex-tsport": "file:../collatex/collatex-tsport",
		"events": "^3.3.0",
		"lucide-svelte": "^0.577.0",
		"nanoid": "^5.1.6",
		"triiiceratops": "file:../triiiceratops"
	}
}
